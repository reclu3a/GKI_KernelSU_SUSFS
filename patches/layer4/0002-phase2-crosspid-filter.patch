 }
 
+#ifdef CONFIG_KSU_SUSFS_SUS_MAP
+/* Layer 4 P5: cross-pid maps filter — hide sensitive .so paths from
+ * third-party apps reading OTHER processes' /proc/<pid>/maps.
+ * When caller is uid>=10000 and target is a different task and the mapped
+ * file path contains a sensitive keyword, replace the line with [anon]. */
+static bool susfs_crosspid_map_should_hide(struct seq_file *m,
+					    struct file *file)
+{
+	struct proc_maps_private *priv = m->private;
+	struct task_struct *target;
+	const unsigned char *name;
+	if (!file || !priv)
+		return false;
+	target = priv->task;
+	if (!target || target == current)
+		return false;
+	if (__kuid_val(current_uid()) < 10000)
+		return false;
+	name = file->f_path.dentry->d_name.name;
+	if (!name)
+		return false;
+	if (strstr((const char *)name, "libpine"))
+		return true;
+	if (strstr((const char *)name, "libzygisk"))
+		return true;
+	if (strstr((const char *)name, "KernelSU"))
+		return true;
+	if (strstr((const char *)name, "tricky_store"))
+		return true;
+	if (strstr((const char *)name, "TEESimulator"))
+		return true;
+	if (strstr((const char *)name, "ksu_susfs"))
+		return true;
+	return false;
+}
+#endif
+
 static void
 show_map_vma(struct seq_file *m, struct vm_area_struct *vma)
 {
@@ -346,6 +383,14 @@
 	 * special [heap] marker for the heap:
 	 */
 	if (file) {
+#ifdef CONFIG_KSU_SUSFS_SUS_MAP
+		if (susfs_crosspid_map_should_hide(m, file)) {
+			seq_pad(m, ' ');
+			seq_puts(m, "[anon]");
+			seq_putc(m, '\n');
+			return;
+		}
+#endif
 		seq_pad(m, ' ');
 		seq_file_path(m, file, "\n");
 		goto done;
