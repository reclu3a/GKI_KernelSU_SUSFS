@@ -391,6 +391,35 @@
 	return ret;
 }
 
+#ifdef CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG
+/* Layer 4 P4: check if target process is a sensitive daemon (ksud, tricky_store
+ * supervisor, TEESimulator, zygisk, etc.) and caller is a third-party app.
+ * Returns true if this cross-pid cmdline read should be faked. */
+static bool susfs_should_fake_pid_cmdline(struct task_struct *tsk)
+{
+	const char *comm;
+	kuid_t uid = current_uid();
+	if (tsk == current)
+		return false;
+	if (__kuid_val(uid) < 10000)
+		return false;
+	comm = tsk->comm;
+	if (!strncmp(comm, "ksud", 4))
+		return true;
+	if (!strncmp(comm, "TEESim", 6))
+		return true;
+	if (!strncmp(comm, "supervis", 8))
+		return true;
+	if (!strncmp(comm, "susfsd", 6))
+		return true;
+	if (strstr(comm, "zygisk"))
+		return true;
+	if (strstr(comm, "amber") || strstr(comm, "miui_therm"))
+		return true;
+	return false;
+}
+#endif
+
 static ssize_t proc_pid_cmdline_read(struct file *file, char __user *buf,
 				     size_t count, loff_t *pos)
 {
@@ -402,6 +431,22 @@
 	tsk = get_proc_task(file_inode(file));
 	if (!tsk)
 		return -ESRCH;
+
+#ifdef CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG
+	if (susfs_should_fake_pid_cmdline(tsk)) {
+		static const char fake_cmdline[] = "/system/bin/init";
+		size_t flen = sizeof(fake_cmdline) - 1;
+		put_task_struct(tsk);
+		if (*pos >= (loff_t)flen)
+			return 0;
+		if (count > flen - *pos)
+			count = flen - *pos;
+		if (copy_to_user(buf, fake_cmdline + *pos, count))
+			return -EFAULT;
+		*pos += count;
+		return count;
+	}
+#endif
 	ret = get_task_cmdline(tsk, buf, count, pos);
 	put_task_struct(tsk);
 	if (ret > 0)
diff --color -urN a/fs/proc/task_mmu.c b/fs/proc/task_mmu.c
