diff --color -urN a/fs/proc/cmdline.c b/fs/proc/cmdline.c
--- a/fs/proc/cmdline.c	2026-04-18 12:41:35
+++ b/fs/proc/cmdline.c	2026-04-18 12:42:36
@@ -3,16 +3,80 @@
 #include <linux/init.h>
 #include <linux/proc_fs.h>
 #include <linux/seq_file.h>
+#include <linux/string.h>
 
+/* Layer 4 P3: sanitize hardware fingerprint keys from /proc/cmdline.
+ * Strip tokens beginning with any of these prefixes (and their values). */
+static const char * const susfs_cmdline_skip_prefixes[] = {
+	"hwid.",
+	"msm_drm.oled_wp=",
+	"msm_drm.dsi_display0=",
+	"swinfo.fingerprint=",
+	"mtdoops.fingerprint=",
+	"androidboot.oled_wp=",
+	NULL,
+};
+
+static char susfs_sanitized_cmdline[4096] __read_mostly;
+static bool susfs_sanitized_ready __read_mostly;
+
+static bool susfs_cmdline_token_skip(const char *tok, size_t tok_len)
+{
+	int i;
+	for (i = 0; susfs_cmdline_skip_prefixes[i]; i++) {
+		size_t plen = strlen(susfs_cmdline_skip_prefixes[i]);
+		if (tok_len >= plen &&
+		    !strncmp(tok, susfs_cmdline_skip_prefixes[i], plen))
+			return true;
+	}
+	return false;
+}
+
+static void susfs_cmdline_sanitize_once(void)
+{
+	const char *p = saved_command_line;
+	char *out = susfs_sanitized_cmdline;
+	size_t remain = sizeof(susfs_sanitized_cmdline) - 1;
+	bool first = true;
+
+	while (*p) {
+		const char *end;
+		size_t tlen;
+		while (*p == ' ') p++;
+		if (!*p) break;
+		end = p;
+		while (*end && *end != ' ') end++;
+		tlen = end - p;
+		if (!susfs_cmdline_token_skip(p, tlen)) {
+			if (!first && remain > 0) {
+				*out++ = ' ';
+				remain--;
+			}
+			if (tlen > remain) tlen = remain;
+			memcpy(out, p, tlen);
+			out += tlen;
+			remain -= tlen;
+			first = false;
+		}
+		p = end;
+	}
+	*out = '\0';
+	susfs_sanitized_ready = true;
+}
+
 static int cmdline_proc_show(struct seq_file *m, void *v)
 {
-	seq_puts(m, saved_command_line);
+	if (susfs_sanitized_ready)
+		seq_puts(m, susfs_sanitized_cmdline);
+	else
+		seq_puts(m, saved_command_line);
 	seq_putc(m, '\n');
 	return 0;
 }
 
 static int __init proc_cmdline_init(void)
 {
+	susfs_cmdline_sanitize_once();
 	proc_create_single("cmdline", 0, NULL, cmdline_proc_show);
 	return 0;
 }
diff --color -urN a/fs/proc/version.c b/fs/proc/version.c
--- a/fs/proc/version.c	2026-04-18 12:41:35
+++ b/fs/proc/version.c	2026-04-18 12:42:03
@@ -6,12 +6,26 @@
 #include <linux/seq_file.h>
 #include <linux/utsname.h>
 
+#ifdef CONFIG_KSU_SUSFS_SPOOF_UNAME
+extern void susfs_spoof_uname(struct new_utsname* tmp);
+#endif
+
 static int version_proc_show(struct seq_file *m, void *v)
 {
+#ifdef CONFIG_KSU_SUSFS_SPOOF_UNAME
+	struct new_utsname tmp;
+	memcpy(&tmp, utsname(), sizeof(tmp));
+	susfs_spoof_uname(&tmp);
 	seq_printf(m, linux_proc_banner,
+		tmp.sysname,
+		tmp.release,
+		tmp.version);
+#else
+	seq_printf(m, linux_proc_banner,
 		utsname()->sysname,
 		utsname()->release,
 		utsname()->version);
+#endif
 	return 0;
 }
 
